{
  "name": "@shelf/table-of-contents",
  "version": "1.3.4",
  "description": "Fork of node-toc to reduce bundle size & rewritten in TypeScript",
  "license": "MIT",
  "author": {
    "name": "Vlad Holubiev",
    "email": "vlad@shelf.io",
    "url": "https://shelf.io"
  },
  "sideEffects": false,
  "type": "module",
  "exports": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rm -rf lib/ && tsc",
    "coverage": "yarn test --coverage",
    "lint": "oxfmt && eslint . --fix",
    "lint:ci": "oxfmt --check && eslint .",
    "lint:size": "size-limit",
    "prepack": "yarn build",
    "test": "TZ=UTC jest src",
    "test:watch": "TZ=UTC jest src --watch",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch"
  },
  "lint-staged": {
    "*.{html,md,yml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{js,ts,json}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "entities": "5.0.0",
    "lodash-es": "4.17.21",
    "slug": "9.1.0"
  },
  "devDependencies": {
    "@shelf/eslint-config": "6.3.0",
    "@shelf/prettier-config": "1.1.1",
    "@shelf/tsconfig": "0.1.0",
    "@size-limit/esbuild-why": "11.2.0",
    "@size-limit/preset-small-lib": "11.2.0",
    "@swc/core": "1.11.8",
    "@swc/jest": "0.2.37",
    "@types/jest": "29.5.14",
    "@types/lodash-es": "4.17.12",
    "@types/node": "20.8.9",
    "@types/slug": "5.0.9",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "15.5.1",
    "oxfmt": "0.41.0",
    "size-limit": "11.2.0",
    "ts-jest-resolver": "2.0.1",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public"
  }
}
